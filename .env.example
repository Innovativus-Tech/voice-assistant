# ── LLM Brain ──────────────────────────────────────────────────
# OPTION 1 (recommended): Groq — free, very fast, no provider setup
# Get key at https://console.groq.com  (free account)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Auto-fallback chain (no changes needed):
#   llama-3.3-70b-versatile  →  groq/compound (no limit)  →  groq/compound-mini (no limit)

# OPTION 2: Hugging Face (requires enabling providers at
#           huggingface.co/settings/inference-providers)
# HF_TOKEN=your_hf_token_here
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Whisper STT ────────────────────────────────────────────────
# tiny (fastest) | base | small | medium (most accurate)
WHISPER_MODEL=base

# ── Supertonic TTS ─────────────────────────────────────────────
# M1-M5 = male voices, F1-F5 = female voices
VOICE_STYLE=F1

# ── Mic sensitivity ────────────────────────────────────────────
# Lower = picks up quieter sounds (0.005–0.05)
SILENCE_THRESHOLD=0.01
